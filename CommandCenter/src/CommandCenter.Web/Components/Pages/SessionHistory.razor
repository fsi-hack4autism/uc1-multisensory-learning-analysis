@page "/sessions/history"
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav

<PageTitle>Session History — Learning Command Center</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <div>
            <h1 class="h4 mb-0 fw-semibold">Session History</h1>
            <p class="text-muted small mb-0 mt-1">All previously analyzed learning sessions</p>
        </div>
        <a href="/" class="btn btn-primary">
            <i class="bi bi-upload me-1"></i> New Session
        </a>
    </div>

    @* Status filter pills *@
    <div class="d-flex flex-wrap gap-2 mb-4">
        @foreach (var f in _filters)
        {
            var isActive = _activeFilter == f.Key;
            <button class="btn btn-sm @(isActive ? "btn-primary" : "btn-outline-secondary")"
                    @onclick="() => SetFilter(f.Key)">
                @f.Label
                @if (_statusCounts.TryGetValue(f.Key, out var cnt) && cnt > 0)
                {
                    <span class="badge ms-1 @(isActive ? "bg-white text-primary" : "bg-secondary text-white")">@cnt</span>
                }
            </button>
        }
    </div>

    @if (_loading)
    {
        <div class="d-flex justify-content-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading…</span>
            </div>
        </div>
    }
    else if (_error is not null)
    {
        <div class="alert alert-danger d-flex align-items-center gap-2">
            <i class="bi bi-exclamation-triangle-fill fs-5"></i>
            <span>@_error</span>
        </div>
    }
    else if (_sessions.Count == 0)
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-collection-play fs-1 d-block mb-3 text-secondary"></i>
            @if (_activeFilter == "All")
            {
                <h5>No sessions yet</h5>
                <p class="small">Upload a learning session recording to get started.</p>
                <a href="/" class="btn btn-primary">
                    <i class="bi bi-upload me-1"></i>Upload Session
                </a>
            }
            else
            {
                <h5>No @_activeFilter sessions</h5>
                <button class="btn btn-sm btn-outline-secondary mt-2" @onclick='() => SetFilter("All")'>
                    Clear filter
                </button>
            }
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" style="font-size:.875rem">
                    <thead style="background:#F8FAFC">
                        <tr>
                            <th class="ps-3">#</th>
                            <th>Session Title</th>
                            <th>Date</th>
                            <th>Status</th>
                            <th>Health</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @{int rowNum = (_page - 1) * _pageSize;}
                        @foreach (var s in VisibleSessions)
                        {
                            rowNum++;
                            var score = s.SessionHealthScore.HasValue ? (int)(s.SessionHealthScore.Value * 100) : (int?)null;
                            var scoreCls = score.HasValue ? (score >= 75 ? "text-cc-green" : score >= 50 ? "text-cc-amber" : "text-cc-red") : "text-muted";
                            <tr>
                                <td class="ps-3 text-muted">@rowNum</td>
                                <td class="fw-medium">@s.Title</td>
                                <td class="text-muted">@s.CreatedAt.ToString("yyyy-MM-dd")</td>
                                <td>
                                    @{
                                        var (badgeCls, badgeLabel) = s.Status switch
                                        {
                                            "Completed"  => ("badge-complete",   "✓ Complete"),
                                            "Failed"     => ("badge-failed",     "✗ Failed"),
                                            "Processing" or "Transcribing" or "Analyzing" or "Uploaded"
                                                         => ("badge-processing", s.Status + "…"),
                                            _            => ("badge-waiting",    s.Status)
                                        };
                                    }
                                    <span class="badge @badgeCls">@badgeLabel</span>
                                    @if (s.Status == "Failed" && s.ErrorMessage is not null)
                                    {
                                        <div class="text-danger mt-1" style="font-size:.7rem;max-width:220px" title="@s.ErrorMessage">
                                            @(s.ErrorMessage.Length > 60 ? s.ErrorMessage[..57] + "…" : s.ErrorMessage)
                                        </div>
                                    }
                                </td>
                                <td>
                                    @if (score.HasValue)
                                    {
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="progress flex-grow-1" style="height:6px;min-width:60px;border-radius:3px">
                                                <div class="progress-bar @(score >= 75 ? "bg-cc-green" : score >= 50 ? "bg-cc-amber" : "bg-cc-red")"
                                                     style="width:@score%"></div>
                                            </div>
                                            <span class="fw-semibold @scoreCls">@score</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td>
                                    <a href="/sessions/@s.Id" class="btn btn-sm btn-outline-primary">View →</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (_totalCount > _pageSize)
        {
            <nav class="mt-3">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(_page <= 1 ? "disabled" : "")">
                        <button class="page-link" @onclick="PrevPage">← Previous</button>
                    </li>
                    <li class="page-item disabled">
                        <span class="page-link">Page @_page of @TotalPages</span>
                    </li>
                    <li class="page-item @(_page >= TotalPages ? "disabled" : "")">
                        <button class="page-link" @onclick="NextPage">Next →</button>
                    </li>
                </ul>
            </nav>
        }

        @* Trend summary *@
        @if (_sessions.Count > 0)
        {
            var completed = _sessions.Where(s => s.SessionHealthScore.HasValue).ToList();
            if (completed.Count > 0)
            {
                var avg = (int)(completed.Average(s => s.SessionHealthScore!.Value) * 100);
                var failed = _sessions.Count(s => s.Status == "Failed");
                <div class="mt-4 p-3 rounded" style="background:#F8FAFC;border:1px solid #E2E8F0;font-size:.82rem;color:#64748B">
                    Average Health: <strong class="text-cc-blue">@avg</strong>
                    &nbsp;·&nbsp; Sessions: <strong>@_sessions.Count</strong>
                    @if (failed > 0) { <span> &nbsp;·&nbsp; Failed: <strong class="text-cc-red">@failed</strong></span> }
                </div>
            }
        }
    }
</div>

@code {
    private List<SessionSummaryDto> _sessions = [];
    private bool _loading = true;
    private string? _error;
    private int _page = 1;
    private int _pageSize = 25;
    private int _totalCount = 0;
    private int TotalPages => (int)Math.Ceiling((double)_totalCount / _pageSize);
    private string _activeFilter = "All";

    private Dictionary<string, int> _statusCounts = [];

    private sealed record FilterDef(string Key, string Label);

    private static readonly List<FilterDef> _filters =
    [
        new("All",        "All"),
        new("Completed",  "✓ Completed"),
        new("Failed",     "✗ Failed"),
        new("Processing", "Processing"),
        new("Uploaded",   "Uploaded"),
    ];

    private IEnumerable<SessionSummaryDto> VisibleSessions =>
        _activeFilter == "All"
            ? _sessions
            : _sessions.Where(s => s.Status == _activeFilter);

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            var client = HttpClientFactory.CreateClient("CommandCenterApi");
            var result = await client.GetFromJsonAsync<PagedResult<SessionSummaryDto>>(
                $"/api/sessions?page={_page}&pageSize={_pageSize}");
            _sessions = result?.Items ?? [];
            _totalCount = result?.TotalCount ?? 0;

            _statusCounts = _sessions
                .GroupBy(s => s.Status)
                .ToDictionary(g => g.Key, g => g.Count());
        }
        catch (Exception ex)
        {
            _error = $"Failed to load session history: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void SetFilter(string key) => _activeFilter = key;
    private async Task PrevPage() { if (_page > 1) { _page--; await LoadAsync(); } }
    private async Task NextPage() { if (_page < TotalPages) { _page++; await LoadAsync(); } }

    private record SessionSummaryDto(
        Guid Id, string Title, string LearnerName, string Status,
        DateTimeOffset CreatedAt, string CreatedAtTimeZone,
        double? EngagementScore, double? AttentionScore,
        double? SessionHealthScore, int? SignalCount,
        string? ErrorMessage);

    private record PagedResult<T>(List<T> Items, int TotalCount, int Page, int PageSize);
}
