@page "/sessions/{Id:guid}"
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav

<PageTitle>Session Detail</PageTitle>

<div class="container-fluid py-4">
    <div class="mb-3">
        <a href="/" class="btn btn-sm btn-outline-secondary">&larr; Back to Dashboard</a>
    </div>

    @if (_loading)
    {
        <div class="d-flex justify-content-center py-5">
            <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading…</span></div>
        </div>
    }
    else if (_error is not null)
    {
        <div class="alert alert-danger">@_error</div>
    }
    else if (_session is not null)
    {
        @* ── Top Section ──────────────────────────────────────────────────────── *@
        <div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-3">
            <div>
                <h2 class="h3 mb-1">@_session.Title</h2>
                <div class="text-muted mb-1">@_session.LearnerName</div>
                @if (_session.Description is not null)
                {
                    <p class="text-muted small mb-0">@_session.Description</p>
                }
                <div class="text-muted small mt-1">
                    Uploaded @_session.CreatedAt.ToString("MMM d, yyyy HH:mm") @_session.CreatedAtTimeZone
                    @if (_session.ProcessedAt.HasValue)
                    {
                        <span> &middot; Processed @_session.ProcessedAt.Value.ToString("MMM d, yyyy HH:mm") @_session.ProcessedAtTimeZone</span>
                    }
                    @if (_session.Duration.HasValue)
                    {
                        <span> &middot; @FormatDuration(_session.Duration.Value)</span>
                    }
                </div>
            </div>
            <div class="d-flex flex-column align-items-end gap-2">
                <span class="badge fs-6 @StatusBadge(_session.Status)">@_session.Status</span>
                @if (_session.Metrics is not null)
                {
                    <div class="text-center">
                        <div class="display-6 fw-bold @HealthScoreColor(_session.Metrics.SessionHealthScore)">
                            @((_session.Metrics.SessionHealthScore * 100).ToString("F0"))
                        </div>
                        <div class="small text-muted">Session Health Score</div>
                    </div>
                }
            </div>
        </div>

        @* ── Processing status banner when not complete ───────────────────────── *@
        @if (_session.Status is "Processing" or "Transcribing" or "Analyzing" or "Uploaded")
        {
            <div class="alert alert-info d-flex align-items-center gap-2 mb-4">
                <div class="spinner-border spinner-border-sm" role="status"></div>
                <span>Processing status: <strong>@_session.Status</strong> — results will appear when analysis completes.</span>
            </div>
        }
        @if (_session.Status == "Failed" && _session.ErrorMessage is not null)
        {
            <div class="alert alert-danger mb-4">
                <strong>Processing failed:</strong> @_session.ErrorMessage
            </div>
        }

        @* ── Metric Cards ─────────────────────────────────────────────────────── *@
        @if (_session.Metrics is not null)
        {
            var m = _session.Metrics;
            <div class="row g-3 mb-4">
                @MetricCard("Engagement", m.EngagementScore, "success", "bi-lightning-charge-fill")
                @MetricCard("Attention", m.AttentionScore, "info", "bi-eye-fill")
                @MetricCard("Comprehension", m.ComprehensionScore, "primary", "bi-lightbulb-fill")
                @MetricCard("Confusion Risk", m.ConfusionScore, "danger", "bi-question-circle-fill")
                @MetricCard("Frustration Risk", m.FrustrationScore, "warning", "bi-emoji-frown-fill")
                <div class="col-sm-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-body">
                            <div class="text-muted small mb-2">Instructor / Learner Talk Ratio</div>
                            <div class="d-flex justify-content-between small mb-1">
                                <span>Instructor</span>
                                <span class="text-muted">Not Available</span>
                            </div>
                            <div class="progress mb-2" style="height:6px">
                                <div class="progress-bar bg-secondary" style="width:0%"></div>
                            </div>
                            <div class="d-flex justify-content-between small mb-1">
                                <span>Learner</span>
                                <span class="text-muted">Not Available</span>
                            </div>
                            <div class="progress" style="height:6px">
                                <div class="progress-bar bg-primary" style="width:0%"></div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-body">
                            <div class="text-muted small mb-2">Session Stats</div>
                            <div class="row g-2 text-center">
                                <div class="col-6">
                                    <div class="fw-semibold">@m.TotalWordsSpoken.ToString("N0")</div>
                                    <div class="text-muted small">Words</div>
                                </div>
                                <div class="col-6">
                                    <div class="fw-semibold">@m.SpeakingRateWordsPerMinute.ToString("F0") wpm</div>
                                    <div class="text-muted small">Speaking Rate</div>
                                </div>
                                <div class="col-4">
                                    <div class="fw-semibold">@m.QuestionCount</div>
                                    <div class="text-muted small">Questions</div>
                                </div>
                                <div class="col-4">
                                    <div class="fw-semibold">@m.PauseCount</div>
                                    <div class="text-muted small">Pauses</div>
                                </div>
                                <div class="col-4">
                                    <div class="fw-semibold">@m.FillerWordCount</div>
                                    <div class="text-muted small">Fillers</div>
                                </div>
                            </div>
                            <div class="text-muted small mt-2">Computed @m.ComputedAt.ToString("MMM d, yyyy HH:mm") @m.ComputedAtTimeZone</div>
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="row g-4">
            @* ── Left column ─────────────────────────────────────────────────── *@
            <div class="col-lg-7">

                @* AI Session Summary *@
                @if (_session.Analysis is not null)
                {
                    <div class="card mb-4 border-0 shadow-sm">
                        <div class="card-header fw-semibold bg-transparent">
                            <span>&#127916;</span> Session Summary
                        </div>
                        <div class="card-body">
                            <p class="mb-3">@_session.Analysis.Summary</p>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="text-muted small mb-1">&#128218; Key Topics</div>
                                    <p class="mb-0">@_session.Analysis.KeyTopics</p>
                                </div>
                                <div class="col-md-6">
                                    <div class="text-muted small mb-1">&#127919; Inferred Objectives</div>
                                    <p class="mb-0">@_session.Analysis.LearningObjectivesInferred</p>
                                </div>
                                <div class="col-md-6">
                                    <div class="text-muted small mb-1">&#9989; Strengths</div>
                                    <p class="mb-0">@_session.Analysis.StrengthsObserved</p>
                                </div>
                                <div class="col-md-6">
                                    <div class="text-muted small mb-1">&#128270; Areas for Improvement</div>
                                    <p class="mb-0">@_session.Analysis.AreasForImprovement</p>
                                </div>
                            </div>
                            <div class="text-muted small mt-3">
                                Analyzed @_session.Analysis.AnalyzedAt.ToString("MMM d, yyyy HH:mm") @_session.Analysis.AnalyzedAtTimeZone
                                &middot; Model: @_session.Analysis.ModelVersion
                            </div>
                        </div>
                    </div>
                }

                @* Recommendations *@
                @if (_session.Recommendations.Count > 0)
                {
                    <div class="card mb-4 border-0 shadow-sm">
                        <div class="card-header fw-semibold bg-transparent">&#128161; Recommended Interventions</div>
                        <div class="list-group list-group-flush">
                            @foreach (var r in _session.Recommendations.OrderBy(r => r.Priority))
                            {
                                <div class="list-group-item border-0">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <div class="fw-semibold">@r.Title</div>
                                            <div class="text-muted small">@r.Body</div>
                                            <div class="text-muted small mt-1">
                                                @r.GeneratedAt.ToString("MMM d, yyyy HH:mm") @r.GeneratedAtTimeZone
                                            </div>
                                        </div>
                                        <span class="badge bg-secondary ms-3">@r.Type</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                @* Transcript Viewer *@
                @if (_session.Transcript.Count > 0)
                {
                    <div class="card mb-4 border-0 shadow-sm">
                        <div class="card-header d-flex justify-content-between align-items-center bg-transparent">
                            <span class="fw-semibold">&#128221; Transcript</span>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => _showTranscript = !_showTranscript">
                                @(_showTranscript ? "Collapse" : "Expand")
                            </button>
                        </div>
                        @if (_showTranscript)
                        {
                            <div class="card-body" style="max-height:420px;overflow-y:auto" id="transcript-viewer">
                                @foreach (var seg in _session.Transcript.OrderBy(t => t.SequenceIndex))
                                {
                                    var isHighlighted = _highlightedSegmentIndex == seg.SequenceIndex;
                                    <div id="seg-@seg.SequenceIndex"
                                         class="mb-2 p-2 rounded @(isHighlighted ? "bg-warning bg-opacity-25 border border-warning" : "")">
                                        <span class="badge bg-light text-dark me-2">@FormatDuration(seg.StartTime)</span>
                                        @if (seg.SpeakerTag is not null)
                                        {
                                            <span class="badge bg-secondary me-1">@seg.SpeakerTag</span>
                                        }
                                        <span>@seg.Text</span>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>

            @* ── Right column ────────────────────────────────────────────────── *@
            <div class="col-lg-5">

                @* Key Moments Timeline *@
                @if (_session.Signals.Count > 0)
                {
                    <div class="card mb-4 border-0 shadow-sm">
                        <div class="card-header fw-semibold bg-transparent">&#9201; Key Moments Timeline</div>
                        <div class="card-body">
                            <p class="text-muted small mb-3">
                                Signals are low/medium/high confidence learning indicators only — not clinical findings.
                            </p>
                            <div style="max-height:340px;overflow-y:auto">
                                @foreach (var sig in _session.Signals.OrderBy(s => s.Timestamp))
                                {
                                    <div class="d-flex gap-2 mb-2 align-items-start @(IsClickableSignal(sig) ? "cursor-pointer" : "")"
                                         @onclick="() => JumpToSignal(sig)" style="cursor:pointer">
                                        <div class="text-nowrap text-muted small pt-1" style="min-width:3.5rem">
                                            @FormatDuration(sig.Timestamp)
                                        </div>
                                        <div class="flex-grow-1">
                                            <span class="badge @SignalTypeBadge(sig.SignalType) me-1">@sig.SignalType</span>
                                            <span class="badge @LevelBadge(sig.Level) me-1">@sig.Level</span>
                                            @if (sig.Notes is not null)
                                            {
                                                <div class="text-muted small mt-1">@sig.Notes</div>
                                            }
                                        </div>
                                        <div class="text-muted small pt-1">@sig.ConfidenceScore.ToString("P0")</div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }

                @* Learning Signals Table *@
                @if (_session.Signals.Count > 0)
                {
                    <div class="card mb-4 border-0 shadow-sm">
                        <div class="card-header d-flex justify-content-between align-items-center bg-transparent">
                            <span class="fw-semibold">&#128202; All Learning Signals</span>
                            <button class="btn btn-sm btn-outline-secondary"
                                    @onclick="() => _showSignalsTable = !_showSignalsTable">
                                @(_showSignalsTable ? "Collapse" : "Expand")
                            </button>
                        </div>
                        @if (_showSignalsTable)
                        {
                            <div style="max-height:300px;overflow-y:auto">
                                <table class="table table-sm table-hover mb-0">
                                    <thead class="table-light sticky-top">
                                        <tr>
                                            <th>Time</th>
                                            <th>Signal</th>
                                            <th>Level</th>
                                            <th>Conf.</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var sig in _session.Signals.OrderBy(s => s.Timestamp))
                                        {
                                            <tr style="cursor:pointer" @onclick="() => JumpToSignal(sig)">
                                                <td class="text-nowrap">@FormatDuration(sig.Timestamp)</td>
                                                <td><span class="badge @SignalTypeBadge(sig.SignalType)">@sig.SignalType</span></td>
                                                <td>@sig.Level</td>
                                                <td>@sig.ConfidenceScore.ToString("P0")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                }

                @* Visual Signal Panel *@
                @if (_session.VideoAnalysis is not null)
                {
                    <div class="card mb-4 border-0 shadow-sm">
                        <div class="card-header fw-semibold bg-transparent">&#127909; Visual Signal Analysis</div>
                        <div class="card-body">
                            <p class="text-muted small mb-3">
                                Visual signals are <strong>low confidence indicators only</strong> — not clinical findings.
                                Wording such as "Possible disengagement detected" is a signal, not a diagnosis.
                            </p>
                            @if (_session.VideoAnalysis.Labels.Count > 0)
                            {
                                <div class="mb-3">
                                    <div class="text-muted small mb-2">Detected Visual Labels</div>
                                    @foreach (var lbl in _session.VideoAnalysis.Labels.OrderByDescending(l => l.Confidence))
                                    {
                                        <div class="d-flex justify-content-between small mb-1">
                                            <span>@lbl.Description</span>
                                            <span class="text-muted">@lbl.Confidence.ToString("P0")</span>
                                        </div>
                                        <div class="progress mb-2" style="height:5px">
                                            <div class="progress-bar bg-secondary"
                                                 style="width:@((lbl.Confidence * 100).ToString("F0"))%"></div>
                                        </div>
                                    }
                                </div>
                            }
                            <div class="text-muted small">
                                Analyzed @_session.VideoAnalysis.AnalyzedAt.ToString("MMM d, yyyy HH:mm") @_session.VideoAnalysis.AnalyzedAtTimeZone
                            </div>
                        </div>
                    </div>
                }
                else if (_session.Status == "Completed")
                {
                    <div class="card mb-4 border-0 shadow-sm">
                        <div class="card-body text-muted small text-center py-4">
                            &#127909; Video analysis not enabled for this session.
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public Guid Id { get; set; }

    private SessionDetailDto? _session;
    private bool _loading = true;
    private string? _error;
    private bool _showTranscript = false;
    private bool _showSignalsTable = false;
    private int? _highlightedSegmentIndex;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("CommandCenterApi");
            _session = await client.GetFromJsonAsync<SessionDetailDto>($"/api/sessions/{Id}");
        }
        catch (Exception ex)
        {
            _error = $"Failed to load session: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void JumpToSignal(LearningSignalDto sig)
    {
        // Find nearest transcript segment by start time
        if (_session?.Transcript.Count > 0)
        {
            var nearest = _session.Transcript
                .OrderBy(t => Math.Abs((t.StartTime - sig.Timestamp).TotalSeconds))
                .FirstOrDefault();
            if (nearest is not null)
            {
                _highlightedSegmentIndex = nearest.SequenceIndex;
                _showTranscript = true;
            }
        }
    }

    private static bool IsClickableSignal(LearningSignalDto sig) => true;

    private static string FormatDuration(TimeSpan t) =>
        t.TotalHours >= 1 ? t.ToString(@"h\:mm\:ss") : t.ToString(@"m\:ss");

    private static string StatusBadge(string status) => status switch
    {
        "Completed" => "bg-success",
        "Failed" => "bg-danger",
        "Processing" or "Transcribing" or "Analyzing" => "bg-warning text-dark",
        _ => "bg-secondary"
    };

    private static string HealthScoreColor(double score) => score switch
    {
        >= 0.75 => "text-success",
        >= 0.50 => "text-warning",
        _ => "text-danger"
    };

    private static string SignalTypeBadge(string type) => type switch
    {
        "EngagementIndicator" => "bg-success",
        "AttentionIndicator" => "bg-info text-dark",
        "ComprehensionIndicator" => "bg-primary",
        "FrustrationIndicator" => "bg-warning text-dark",
        "ConfusionIndicator" => "bg-danger",
        "StimmingIndicator" => "bg-secondary",
        _ => "bg-light text-dark"
    };

    private static string LevelBadge(string level) => level switch
    {
        "High" => "bg-danger",
        "Medium" => "bg-warning text-dark",
        "Low" => "bg-success",
        _ => "bg-light text-dark"
    };

    private RenderFragment MetricCard(string label, double value, string color, string icon) => __builder =>
    {
        <div class="col-sm-6 col-lg-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted small">@label</span>
                        <span class="fw-bold text-@color">@(value.ToString("P0"))</span>
                    </div>
                    <div class="progress" style="height:8px">
                        <div class="progress-bar bg-@color"
                             style="width:@((value * 100).ToString("F0"))%">
                        </div>
                    </div>
                </div>
            </div>
        </div>;
    };

    // ── Local DTOs ────────────────────────────────────────────────────────────
    private record SessionDetailDto(
        Guid Id, string Title, string LearnerName, string? Description,
        string Status, DateTimeOffset CreatedAt, string CreatedAtTimeZone,
        DateTimeOffset? ProcessedAt, string? ProcessedAtTimeZone,
        TimeSpan? Duration, string? ContentType, string? ErrorMessage,
        List<TranscriptSegmentDto> Transcript,
        List<LearningSignalDto> Signals,
        List<RecommendationDto> Recommendations,
        SessionMetricsDto? Metrics,
        SessionAnalysisDto? Analysis,
        VideoAnalysisDto? VideoAnalysis);

    private record TranscriptSegmentDto(
        int SequenceIndex, TimeSpan StartTime, TimeSpan EndTime,
        string Text, double Confidence, string? SpeakerTag);

    private record LearningSignalDto(
        TimeSpan Timestamp, string SignalType, string Level,
        double ConfidenceScore, string? Notes, string? SourceEvidence);

    private record RecommendationDto(
        string Title, string Body, string Type, int Priority,
        DateTimeOffset GeneratedAt, string GeneratedAtTimeZone);

    private record SessionMetricsDto(
        double EngagementScore, double AttentionScore, double FrustrationScore,
        double ConfusionScore, double ComprehensionScore,
        int TotalWordsSpoken, double SpeakingRateWordsPerMinute,
        int PauseCount, TimeSpan TotalPauseDuration,
        int QuestionCount, int FillerWordCount,
        DateTimeOffset ComputedAt, string ComputedAtTimeZone,
        double SessionHealthScore);

    private record SessionAnalysisDto(
        string Summary, string KeyTopics, string LearningObjectivesInferred,
        string StrengthsObserved, string AreasForImprovement,
        string ModelVersion, DateTimeOffset AnalyzedAt, string AnalyzedAtTimeZone);

    private record VideoAnalysisDto(
        List<VideoLabelDto> Labels, List<VideoShotDto> Shots,
        DateTimeOffset AnalyzedAt, string AnalyzedAtTimeZone);

    private record VideoLabelDto(string Description, double Confidence);
    private record VideoShotDto(TimeSpan StartTime, TimeSpan EndTime);
}
