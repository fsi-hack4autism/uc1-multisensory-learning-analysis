using CommandCenter.Domain.Entities;
using CommandCenter.Domain.Interfaces;
using Microsoft.Extensions.Logging;

namespace CommandCenter.Infrastructure.Services;

public sealed class MetricsEngine : IMetricsEngine
{
    private readonly ILogger<MetricsEngine> _logger;

    private static readonly HashSet<string> FillerWords =
        new(StringComparer.OrdinalIgnoreCase) { "um", "uh", "like", "you know", "basically", "literally", "actually", "so", "right" };

    public MetricsEngine(ILogger<MetricsEngine> logger) => _logger = logger;

    public SessionMetrics Compute(Guid sessionId, List<TranscriptSegment> segments, List<LearningSignal> signals)
    {
        _logger.LogInformation("Computing metrics for session {SessionId}", sessionId);

        var allWords = segments.SelectMany(s => s.Text.Split(' ', StringSplitOptions.RemoveEmptyEntries)).ToList();
        var totalWords = allWords.Count;
        var fillerCount = allWords.Count(w => FillerWords.Contains(w.Trim('.', ',', '?', '!')));
        var questionCount = segments.Count(s => s.Text.TrimEnd().EndsWith('?'));

        var totalDuration = segments.Count > 0
            ? segments.Max(s => s.EndTime) - segments.Min(s => s.StartTime)
            : TimeSpan.Zero;
        var speakingRate = totalDuration.TotalMinutes > 0 ? totalWords / totalDuration.TotalMinutes : 0;

        // Pause detection: gaps > 2 seconds between consecutive segments
        var pauseCount = 0;
        var totalPauseDuration = TimeSpan.Zero;
        for (int i = 1; i < segments.Count; i++)
        {
            var gap = segments[i].StartTime - segments[i - 1].EndTime;
            if (gap.TotalSeconds >= 2)
            {
                pauseCount++;
                totalPauseDuration += gap;
            }
        }

        // Score signals into 0-1 range using weighted averages
        static double ScoreSignals(List<LearningSignal> sigs, SignalType type)
        {
            var relevant = sigs.Where(s => s.SignalType == type).ToList();
            if (relevant.Count == 0) return 0.5;
            return relevant.Average(s => s.Level switch
            {
                SignalLevel.High => s.ConfidenceScore,
                SignalLevel.Medium => s.ConfidenceScore * 0.6,
                _ => s.ConfidenceScore * 0.3
            });
        }

        // Talk ratio: tag segments as instructor (first distinct tag) vs learner (others)
        double? instructorRatio = null;
        double? learnerRatio = null;
        var taggedSegments = segments.Where(s => s.SpeakerTag is not null).ToList();
        if (taggedSegments.Count > 0)
        {
            var totalTaggedDuration = taggedSegments.Sum(s => (s.EndTime - s.StartTime).TotalSeconds);
            if (totalTaggedDuration > 0)
            {
                var speakerGroups = taggedSegments
                    .GroupBy(s => s.SpeakerTag!)
                    .OrderByDescending(g => g.Sum(s => (s.EndTime - s.StartTime).TotalSeconds))
                    .ToList();

                // Largest speaker assumed to be instructor
                var instructorDuration = speakerGroups.FirstOrDefault()?.Sum(s => (s.EndTime - s.StartTime).TotalSeconds) ?? 0;
                instructorRatio = Math.Clamp(instructorDuration / totalTaggedDuration, 0, 1);
                learnerRatio = Math.Clamp(1.0 - instructorRatio.Value, 0, 1);
            }
        }

        // Participation score: learner talk ratio weighted with question/engagement signals
        double? participationScore = null;
        if (learnerRatio.HasValue || signals.Any(s => s.SignalType == SignalType.EngagementIndicator))
        {
            var engagementBase = ScoreSignals(signals, SignalType.EngagementIndicator);
            var talkComponent = learnerRatio ?? 0.5;
            participationScore = Math.Clamp((engagementBase * 0.6) + (talkComponent * 0.4), 0, 1);
        }

        // Energy level: derived from speaking rate, pause frequency, and engagement
        double? energyLevel = null;
        if (totalWords > 0)
        {
            var normalizedRate = Math.Clamp(speakingRate / 160.0, 0, 1); // 160 wpm ≈ baseline energetic pace
            var pausePenalty = totalDuration.TotalMinutes > 0 ? Math.Clamp(pauseCount / (totalDuration.TotalMinutes * 2.0), 0, 1) : 0;
            var engScore = ScoreSignals(signals, SignalType.EngagementIndicator);
            energyLevel = Math.Clamp((normalizedRate * 0.4) + (engScore * 0.4) + ((1.0 - pausePenalty) * 0.2), 0, 1);
        }

        // Confidence level: penalise missing speaker tags, low signal count, short sessions
        var hasSignals = signals.Count >= 3;
        var hasSpeakerTags = taggedSegments.Count > 0;
        var hasAdequateDuration = totalDuration.TotalMinutes >= 1;
        var confidenceLevel = 1.0;
        if (!hasSignals) confidenceLevel -= 0.35;
        if (!hasSpeakerTags) confidenceLevel -= 0.2;
        if (!hasAdequateDuration) confidenceLevel -= 0.25;
        confidenceLevel = Math.Clamp(confidenceLevel, 0.1, 1.0);

        return new SessionMetrics
        {
            SessionId = sessionId,
            OverallEngagementScore = Math.Clamp(ScoreSignals(signals, SignalType.EngagementIndicator), 0, 1),
            OverallAttentionScore = Math.Clamp(ScoreSignals(signals, SignalType.AttentionIndicator), 0, 1),
            OverallFrustrationScore = Math.Clamp(ScoreSignals(signals, SignalType.FrustrationIndicator), 0, 1),
            OverallConfusionScore = Math.Clamp(ScoreSignals(signals, SignalType.ConfusionIndicator), 0, 1),
            OverallComprehensionScore = Math.Clamp(ScoreSignals(signals, SignalType.ComprehensionIndicator), 0, 1),
            TotalWordsSpoken = totalWords,
            SpeakingRateWordsPerMinute = speakingRate,
            PauseCount = pauseCount,
            TotalPauseDuration = totalPauseDuration,
            QuestionCount = questionCount,
            FillerWordCount = fillerCount,
            ParticipationScore = participationScore,
            EnergyLevel = energyLevel,
            InstructorTalkRatio = instructorRatio,
            LearnerTalkRatio = learnerRatio,
            MetricsConfidenceLevel = confidenceLevel,
            ComputedAt = DateTimeOffset.UtcNow
        };
    }
}
