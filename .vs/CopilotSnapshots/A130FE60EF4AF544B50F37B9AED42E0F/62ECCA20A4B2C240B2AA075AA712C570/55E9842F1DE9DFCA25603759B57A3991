/* ── Design token palette (dashboard-mockups.md) ─────────────────────────── */
:root {
    --cc-navy:   #0F172A;
    --cc-blue:   #3B82F6;
    --cc-green:  #22C55E;
    --cc-amber:  #F59E0B;
    --cc-red:    #EF4444;
    --cc-gray:   #94A3B8;
    --cc-surface: #F8FAFC;
}

html, body {
    font-family: 'Inter', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    background-color: var(--cc-surface);
    color: #1E293B;
}

a, .btn-link {
    color: var(--cc-blue);
}

.btn-primary {
    color: #fff;
    background-color: var(--cc-blue);
    border-color: var(--cc-blue);
}

.btn-primary:hover, .btn-primary:focus {
    background-color: #2563EB;
    border-color: #2563EB;
}

.btn-outline-primary {
    color: var(--cc-blue);
    border-color: var(--cc-blue);
}

.btn-outline-primary:hover {
    background-color: var(--cc-blue);
    border-color: var(--cc-blue);
}

.btn:focus, .btn:active:focus, .btn-link.nav-link:focus, .form-control:focus, .form-check-input:focus {
  box-shadow: 0 0 0 0.1rem white, 0 0 0 0.25rem rgba(59,130,246,0.4);
}

/* Health / score color helpers */
.text-cc-green  { color: var(--cc-green)  !important; }
.text-cc-amber  { color: var(--cc-amber)  !important; }
.text-cc-red    { color: var(--cc-red)    !important; }
.text-cc-blue   { color: var(--cc-blue)   !important; }
.text-cc-gray   { color: var(--cc-gray)   !important; }

.bg-cc-green    { background-color: var(--cc-green)  !important; }
.bg-cc-amber    { background-color: var(--cc-amber)  !important; }
.bg-cc-red      { background-color: var(--cc-red)    !important; }
.bg-cc-blue     { background-color: var(--cc-blue)   !important; }

/* Metric card progress bars */
.progress-cc-green .progress-bar { background-color: var(--cc-green); }
.progress-cc-amber .progress-bar { background-color: var(--cc-amber); }
.progress-cc-red   .progress-bar { background-color: var(--cc-red);   }
.progress-cc-blue  .progress-bar { background-color: var(--cc-blue);  }

/* Upload drop zone */
.upload-dropzone {
    border: 2px dashed var(--cc-gray);
    border-radius: 12px;
    background: #fff;
    transition: border-color .2s, background .2s;
    cursor: pointer;
}
.upload-dropzone:hover, .upload-dropzone.drag-over {
    border-color: var(--cc-blue);
    background: #EFF6FF;
}

/* Section header divider */
.section-label {
    font-size: .7rem;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--cc-gray);
    margin-bottom: .5rem;
}

/* Status badge overrides */
.badge-complete   { background-color: var(--cc-green) !important; color: #fff; }
.badge-failed     { background-color: var(--cc-red)   !important; color: #fff; }
.badge-processing { background-color: var(--cc-blue)  !important; color: #fff; }
.badge-waiting    { background-color: var(--cc-gray)  !important; color: #fff; }

/* Pipeline stage track */
.pipeline-track .stage-dot {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: .8rem;
}
.pipeline-track .stage-line {
    flex: 1;
    height: 2px;
    margin-top: 14px;
}

.content {
    padding-top: 1.1rem;
}

h1:focus {
    outline: none;
}

.valid.modified:not([type=checkbox]) {
    outline: 1px solid #26b050;
}

.invalid {
    outline: 1px solid #e50000;
}

.validation-message {
    color: #e50000;
}

/* ── Recording page ─────────────────────────────────────────────────────── */

.recorder-preview-wrap {
    background: #0d0d0d;
    border-radius: 12px;
    min-height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
}

.recorder-preview {
    width: 100%;
    max-height: 320px;
    border-radius: 12px;
    object-fit: cover;
    display: block;
}

.recorder-idle-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    color: #9ca3af;
}
}

.blazor-error-boundary {
    background: url(data:image/svg+xml;base64,) no-repeat 1rem/1.8rem, #b32121;
    padding: 1rem 1rem 1rem 3.7rem;
    color: white;
}

    .blazor-error-boundary::after {
        content: "An error has occurred."
    }

.darker-border-checkbox.form-check-input {
    border-color: #929292;
}

.form-floating > .form-control-plaintext::placeholder, .form-floating > .form-control::placeholder {
    color: var(--bs-secondary-color);
    text-align: end;
}

.form-floating > .form-control-plaintext:focus::placeholder, .form-floating > .form-control:focus::placeholder {
    text-align: start;
}